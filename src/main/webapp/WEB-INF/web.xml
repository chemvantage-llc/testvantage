<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Test Vantage - LTI Advantage Regression Tester</display-name>

    <listener>
        <listener-class>org.testvantage.ObjectifyBootstrapListener</listener-class>
    </listener>

    <filter>
        <filter-name>ObjectifyFilter</filter-name>
        <filter-class>com.googlecode.objectify.ObjectifyFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>ObjectifyFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Home Servlet -->
    <servlet>
        <servlet-name>Home</servlet-name>
        <servlet-class>org.testvantage.HomeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Home</servlet-name>
        <url-pattern>/</url-pattern>
    </servlet-mapping>

    <!-- Dynamic Registration Servlet -->
    <servlet>
        <servlet-name>Registration</servlet-name>
        <servlet-class>org.testvantage.RegistrationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Registration</servlet-name>
        <url-pattern>/registration</url-pattern>
    </servlet-mapping>

    <!-- OIDC Login Initiation -->
    <servlet>
        <servlet-name>OIDCLogin</servlet-name>
        <servlet-class>org.testvantage.OIDCLoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OIDCLogin</servlet-name>
        <url-pattern>/oidc/login</url-pattern>
    </servlet-mapping>

    <!-- OIDC Auth Response -->
    <servlet>
        <servlet-name>OIDCAuth</servlet-name>
        <servlet-class>org.testvantage.OIDCAuthServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OIDCAuth</servlet-name>
        <url-pattern>/oidc/auth</url-pattern>
    </servlet-mapping>

    <!-- LTI Launch -->
    <servlet>
        <servlet-name>Launch</servlet-name>
        <servlet-class>org.testvantage.LaunchServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Launch</servlet-name>
        <url-pattern>/launch</url-pattern>
    </servlet-mapping>

    <!-- Deep Linking Response -->
    <servlet>
        <servlet-name>DeepLinking</servlet-name>
        <servlet-class>org.testvantage.DeepLinkingServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeepLinking</servlet-name>
        <url-pattern>/deeplink</url-pattern>
    </servlet-mapping>

    <!-- JWKS Endpoint -->
    <servlet>
        <servlet-name>JWKS</servlet-name>
        <servlet-class>org.testvantage.JWKSServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>JWKS</servlet-name>
        <url-pattern>/jwks</url-pattern>
    </servlet-mapping>

    <!-- NRPS Endpoint (mock) -->
    <servlet>
        <servlet-name>NRPS</servlet-name>
        <servlet-class>org.testvantage.NRPSServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>NRPS</servlet-name>
        <url-pattern>/nrps/*</url-pattern>
    </servlet-mapping>

    <!-- AGS Endpoints (mock) -->
    <servlet>
        <servlet-name>AGS</servlet-name>
        <servlet-class>org.testvantage.AGSServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AGS</servlet-name>
        <url-pattern>/ags/*</url-pattern>
    </servlet-mapping>

    <!-- OAuth2 Token Endpoint -->
    <servlet>
        <servlet-name>OAuth2Token</servlet-name>
        <servlet-class>org.testvantage.OAuth2TokenServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OAuth2Token</servlet-name>
        <url-pattern>/oauth2/token</url-pattern>
    </servlet-mapping>

    <!-- Test Report Endpoint -->
    <servlet>
        <servlet-name>TestReport</servlet-name>
        <servlet-class>org.testvantage.TestReportServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TestReport</servlet-name>
        <url-pattern>/test-report</url-pattern>
    </servlet-mapping>

    <!-- JWKS Test Suite -->
    <servlet>
        <servlet-name>JwksTest</servlet-name>
        <servlet-class>org.testvantage.JwksTestServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>JwksTest</servlet-name>
        <url-pattern>/test/jwks</url-pattern>
    </servlet-mapping>

    <!-- Auth Token Test Suite -->
    <servlet>
        <servlet-name>AuthTokenTest</servlet-name>
        <servlet-class>org.testvantage.AuthTokenTestServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AuthTokenTest</servlet-name>
        <url-pattern>/test/auth-token</url-pattern>
    </servlet-mapping>

    <!-- Launch Test Suite -->
    <servlet>
        <servlet-name>LaunchTest</servlet-name>
        <servlet-class>org.testvantage.LaunchTestServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LaunchTest</servlet-name>
        <url-pattern>/test/launch</url-pattern>
    </servlet-mapping>

    <!-- Test Status API -->
    <servlet>
        <servlet-name>TestStatusApi</servlet-name>
        <servlet-class>org.testvantage.TestStatusApiServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TestStatusApi</servlet-name>
        <url-pattern>/api/status</url-pattern>
    </servlet-mapping>

    <!-- OpenID Configuration -->
    <servlet>
        <servlet-name>OIDCConfiguration</servlet-name>
        <servlet-class>org.testvantage.OIDCConfigurationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OIDCConfiguration</servlet-name>
        <url-pattern>/.well-known/openid-configuration</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

    <!-- Session Configuration -->
    <session-config>
        <cookie-config>
            <http-only>true</http-only>
            <secure>true</secure>
        </cookie-config>
    </session-config>
</web-app>
